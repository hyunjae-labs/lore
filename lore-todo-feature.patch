+
+export interface ListTodosParams {
+  status?: string;
+  priority?: string;
+  includeArchived?: boolean;
+  limit?: number;
+}
+
+export async function handleListTodos(
+  db: Database.Database,
+  params: ListTodosParams
+): Promise<{ content: Array<{ type: string; text: string }> }> {
