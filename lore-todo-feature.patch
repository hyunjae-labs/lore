+      title: t.title,
+      note: t.note,
+      status: t.status,
+      priority: t.priority,
+      tags: JSON.parse(t.tags) as string[],
+      created_at: t.created_at,
+      completed_at: t.completed_at,
+      archived_at: t.archived_at,
+    })),
+  });
+}
