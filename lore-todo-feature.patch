+    it("status=all이면 완료 포함", () => {
+      const uuid1 = insertTodo(db, { title: "할일", embedding: DUMMY_EMBEDDING });
+      completeTodo(db, uuid1);
+      const results = listTodos(db, { status: "all" });
+      expect(results.map(r => r.uuid)).toContain(uuid1);
