+function makeDb(): Database.Database {
+  const db = new Database(":memory:");
+  sqliteVec.load(db);
+  db.pragma("journal_mode = WAL");
+  db.exec(TODO_SCHEMA_SQL);
+  db.exec(TODO_VEC_SQL);
+  db.exec(TODO_FTS_SQL);
+  return db;
